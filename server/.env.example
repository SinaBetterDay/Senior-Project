# Copy to .env and fill in values. Never commit .env.

# Supabase → Project Settings → Database → Connection string.
#
# 1) DATABASE_URL — "Session pooler" URI (user looks like postgres.<project-ref> @ *.pooler.supabase.com:5432)
# 2) DIRECT_URL — "Direct connection" URI (user postgres @ db.<project-ref>.supabase.co:5432)
#
# Prisma Migrate uses DIRECT_URL. Your app runtime uses DATABASE_URL.
# Replace [YOUR-PASSWORD] with your DB password — no square brackets. Encode special chars in the password (e.g. $ → %24).
# Append ?sslmode=require if not already present.

DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
